# Copy this file to ".env" and adjust if your backend runs somewhere else.
#
# Leave this EMPTY to use the Vite dev proxy (recommended for local dev):
# the app will call "/api/..." and Vite forwards it to http://localhost:3000.
#
# If you deploy the frontend separately from the backend, set the full URL, e.g.
# VITE_API_BASE=https://api.yourdomain.com
VITE_API_BASE=
